rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      // Local bootstrap admin check via email
      return isEmailVerified() && request.auth.token.email == 'infosdn1gabuskulon@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Archives ---
    match /archives/{archiveId} {
      allow read: if true; // Publicly viewable
      
      allow create: if (
        isAdmin() && 
        isValidId(archiveId) &&
        isValidArchive(incoming()) &&
        incoming().uploaderId == request.auth.uid &&
        incoming().createdAt == request.time
      );
      
      allow update: if (
        isAdmin() && 
        isValidArchive(incoming()) &&
        incoming().uploaderId == existing().uploaderId &&
        incoming().createdAt == existing().createdAt &&
        incoming().updatedAt == request.time &&
        (
          // Action: Edit metadata
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'category', 'date', 'filesize', 'type', 'fileUrl', 'updatedAt'])
        )
      );
      
      allow delete: if isAdmin();
    }

    function isValidArchive(data) {
      return (
        data.keys().hasAll(['title', 'category', 'date', 'fileUrl']) &&
        data.title is string && data.title.size() <= 200 &&
        data.category in ['Dokumen', 'Kegiatan', 'Prestasi', 'Event'] &&
        data.date is string && data.date.size() <= 50 &&
        data.fileUrl is string && data.fileUrl.size() <= 1000 &&
        (!('filesize' in data) || (data.filesize is string && data.filesize.size() <= 50)) &&
        (!('type' in data) || (data.type is string && data.type.size() <= 20))
      );
    }

    // --- Staff ---
    match /staff/{staffId} {
      allow read: if true;
      
      allow write: if isAdmin() && isValidId(staffId) && isValidStaff(incoming());
    }

    function isValidStaff(data) {
      return (
        data.keys().hasAll(['name', 'role']) &&
        data.name is string && data.name.size() <= 200 &&
        data.role is string && data.role.size() <= 200 &&
        (!('nip' in data) || (data.nip is string && data.nip.size() <= 100)) &&
        (!('ttl' in data) || (data.ttl is string && data.ttl.size() <= 200)) &&
        (!('edu' in data) || (data.edu is string && data.edu.size() <= 200)) &&
        (!('gol' in data) || (data.gol is string && data.gol.size() <= 50)) &&
        (!('img' in data) || (data.img is string && data.img.size() <= 1000))
      );
    }
  }
}
