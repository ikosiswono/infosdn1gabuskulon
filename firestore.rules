rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      // Local bootstrap admin check via email
      return isEmailVerified() && request.auth.token.email == 'infosdn1gabuskulon@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Archives ---
    match /archives/{archiveId} {
      // Secure List Queries (Eight Pillar)
      allow list: if true; 
      allow get: if true;
      
      allow create: if (
        isAdmin() && 
        isValidId(archiveId) &&
        isValidArchive(incoming()) &&
        incoming().uploaderId == request.auth.uid &&
        incoming().createdAt == request.time &&
        incoming().updatedAt == request.time
      );
      
      allow update: if (
        isAdmin() && 
        isValidArchive(incoming()) &&
        incoming().uploaderId == existing().uploaderId &&
        incoming().createdAt == existing().createdAt &&
        incoming().updatedAt == request.time &&
        (
          // Action: Edit metadata
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'category', 'description', 'tags', 'date', 'filesize', 'type', 'fileUrl', 'updatedAt'])
        )
      );
      
      allow delete: if isAdmin();
    }

    function isValidArchive(data) {
      return (
        data.keys().hasAll(['title', 'category', 'date', 'fileUrl', 'uploaderId', 'createdAt', 'updatedAt']) &&
        data.title is string && data.title.size() <= 200 &&
        data.category is string && data.category.size() <= 100 &&
        data.date is string && data.date.size() <= 50 &&
        data.fileUrl is string && data.fileUrl.size() <= 1000 &&
        data.uploaderId is string && data.uploaderId.size() <= 128 &&
        data.createdAt is timestamp &&
        data.updatedAt is timestamp &&
        (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
        (!('tags' in data) || (data.tags is list && data.tags.size() <= 20)) &&
        (!('filesize' in data) || (data.filesize is string && data.filesize.size() <= 50)) &&
        (!('type' in data) || (data.type is string && data.type.size() <= 20))
      );
    }

    // --- Staff ---
    match /staff/{staffId} {
      allow list: if true;
      allow get: if true;
      
      allow create: if isAdmin() && isValidId(staffId) && isValidStaff(incoming());
      
      allow update: if isAdmin() && isValidStaff(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'role', 'nip', 'ttl', 'edu', 'gol', 'img', 'order'])
      );

      allow delete: if isAdmin();
    }

    // --- Download Logs ---
    match /downloadLogs/{logId} {
      allow create: if (
        isValidLog(incoming()) &&
        incoming().timestamp == request.time
      );
      allow list, get: if true;
    }

    function isValidLog(data) {
      return (
        data.keys().hasAll(['archiveId', 'archiveTitle', 'timestamp']) &&
        data.archiveId is string && data.archiveId.size() <= 128 &&
        data.archiveTitle is string && data.archiveTitle.size() <= 200 &&
        data.timestamp is timestamp &&
        (!('userEmail' in data) || (data.userEmail is string && data.userEmail.size() <= 200)) &&
        (!('userName' in data) || (data.userName is string && data.userName.size() <= 200))
      );
    }

    // --- Categories ---
    match /categories/{categoryId} {
      allow list, get: if true;
      allow create: if isAdmin() && isValidId(categoryId) && isValidCategory(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidCategory(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['name']);
      allow delete: if isAdmin();
    }

    function isValidCategory(data) {
      return (
        data.keys().hasAll(['name', 'createdAt']) &&
        data.name is string && data.name.size() <= 100 &&
        data.createdAt is timestamp
      );
    }

    function isValidStaff(data) {
      return (
        data.keys().hasAll(['name', 'role']) &&
        data.name is string && data.name.size() <= 200 &&
        data.role is string && data.role.size() <= 200 &&
        (!('nip' in data) || (data.nip is string && data.nip.size() <= 100)) &&
        (!('ttl' in data) || (data.ttl is string && data.ttl.size() <= 200)) &&
        (!('edu' in data) || (data.edu is string && data.edu.size() <= 200)) &&
        (!('gol' in data) || (data.gol is string && data.gol.size() <= 50)) &&
        (!('img' in data) || (data.img is string && data.img.size() <= 1000)) &&
        (!('order' in data) || (data.order is number))
      );
    }
  }
}
