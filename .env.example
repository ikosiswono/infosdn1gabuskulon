# ==================================================
# KONFIGURASI APLIKASI
# UPTD SDN 1 GABUSKULON
# ==================================================

APP_NAME="Administrasi UPTD SDN 1 Gabuskulon"
APP_ENV="production"
APP_DEBUG="false"
APP_URL="https://sdn1gabuskulon.sch.id"

# ==================================================
# IDENTITAS SEKOLAH
# ==================================================

SEKOLAH_NAMA="UPTD SDN 1 Gabuskulon"
SEKOLAH_NPSN="xxxxxxxx"
SEKOLAH_ALAMAT="Gabuskulon, Indramayu"
SEKOLAH_EMAIL="sdn1gabuskulon@gmail.com"
SEKOLAH_TELEPON="08xxxxxxxxxx"

# ==================================================
# ADMINISTRATOR
# ==================================================

ADMIN_NAMA="Operator TAS"
ADMIN_EMAIL="admin@sdn1gabuskulon.sch.id"

# ==================================================
# DATABASE
# ==================================================

DB_CONNECTION="mysql"
DB_HOST="localhost"
DB_PORT="3306"
DB_DATABASE="db_sdn1gabuskulon"
DB_USERNAME="root"
DB_PASSWORD="password"

# ==================================================
# AUTH & SECURITY
# ==================================================

APP_KEY="base64:GENERATE_SECRET_KEY"
JWT_SECRET="GENERATE_JWT_SECRET"

# ==================================================
# GEMINI AI CONFIG
# ==================================================

GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ==================================================
# STORAGE & UPLOAD
# ==================================================

UPLOAD_MAX_SIZE="10MB"
UPLOAD_PATH="/uploads"

# ==================================================
# EMAIL / SMTP
# ==================================================

MAIL_MAILER="smtp"
MAIL_HOST="smtp.gmail.com"
MAIL_PORT="587"
MAIL_USERNAME="your_email@gmail.com"
MAIL_PASSWORD="your_app_password"
MAIL_ENCRYPTION="tls"
MAIL_FROM_ADDRESS="admin@sdn1gabuskulon.sch.id"
MAIL_FROM_NAME="UPTD SDN 1 Gabuskulon"

# ==================================================
# WHATSAPP / NOTIFIKASI
# ==================================================

WA_ADMIN="628xxxxxxxxxx"

# ==================================================
# DISCORD WEBHOOK (OPSIONAL)
# ==================================================

DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/xxxx"

# ==================================================
# FITUR APLIKASI
# ==================================================

ENABLE_AI_FEATURE="true"
ENABLE_DASHBOARD="true"
ENABLE_PPDB="false"
ENABLE_EKSKUL="true"
ENABLE_EKINERJA="true"
ENABLE_SURAT_MENYURAT="true"
